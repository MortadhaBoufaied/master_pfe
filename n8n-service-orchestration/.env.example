# N8N Configuration
N8N_HOST=http://localhost:5678
N8N_PORT=5678
N8N_DB_TYPE=postgres
N8N_DB_HOST=postgres
N8N_DB_PORT=5432
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_in_production
N8N_ENCRYPTION_KEY=your_encryption_key_here

# Webhook Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_WEBHOOK_URL_PRODUCTION=https://your-domain.com/webhook
N8N_API_KEY=your_n8n_api_key

# Chatbot Integration
CHATBOT_API_URL=http://localhost:8000/api/chat
CHATBOT_API_KEY=your_chatbot_api_key

# Service Configuration
SERVICE_TIMEOUT_MS=5000
SERVICE_EXECUTION_TIMEOUT_MS=10000
ENABLE_SERVICE_CACHING=true
SERVICE_CACHE_TTL_SECONDS=300

# Backend/Sports Management Services
BACKEND_API_URL=http://localhost:8080/api
BACKEND_API_KEY=your_backend_api_key

# Logging
LOG_LEVEL=info
LOG_FILE=logs/n8n-services.log
LOG_MAX_SIZE_MB=100
LOG_MAX_FILES=10

# Environment
ENVIRONMENT=development
DEBUG=true

# Redis (optional, for distributed caching)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL_SECONDS=30
