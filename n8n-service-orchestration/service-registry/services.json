    {
      "id": "get-user-profile",
      "name": "Get User Profile",
      "description": "Retrieve user profile information",
      "category": "user-management",
      "keywords": ["profile", "my account", "user info", "account details", "personal info", "show my profile", "who am i", "my info"],
      "enabled": true,
      "workflow_id": "get-user-profile",
      "webhook_path": "/webhook/get-user-profile",
      "timeout_ms": 3000,
      "response_type": "direct",
      "requires_authentication": true,
      "parameters": {
        "user_id": {
          "type": "string",
          "required": false,
          "description": "User ID (optional, from session)"
        }
      },
      "responses": {
        "success": "profile_card",
        "error": "error_default"
      }
    },
